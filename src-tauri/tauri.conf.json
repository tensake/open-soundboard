{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "open-soundboard",
  "version": "0.1.0",
  "identifier": "net.10ku.open-soundboard",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Open SoundBoard",
        "width": 1000,
        "height": 800,
        "minWidth": 600,
        "minHeight": 200
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDI1MjI5OEZBMkRDQjFBRkIKUldUN0dzc3QrcGdpSlZOREkwc29BeE1yWWd6N09FQmo3TEpjUS9RN0lyR3ZXOGlEQ1gwYnQ4cjYK",
      "endpoints": [
        "https://github.com/tensake/open-soundboard/releases/latest/download/latest.json"
      ]
    }
  }
}
